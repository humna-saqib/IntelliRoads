<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Vehicle Types (No Trucks) -->
    <vType id="passenger" vClass="passenger" accel="2.6" decel="4.5" sigma="0.5" length="5.0" minGap="2.5" maxSpeed="33.33"/>
    <vType id="motorcycle" vClass="motorcycle" accel="6.0" decel="5.0" sigma="0.5" length="2.0" minGap="1.0" maxSpeed="41.67"/>
    <vType id="bus" vClass="bus" accel="1.2" decel="4.0" sigma="0.5" length="12.0" minGap="3.0" maxSpeed="22.22"/>

    <!-- Emergency types (Red color in SUMO) -->
    <vType id="ambulance" vClass="emergency" guiShape="emergency" color="1,0,0" accel="3.0" decel="5.0" sigma="0.5" length="6.0" minGap="2.0" maxSpeed="38.89"/>
    <vType id="police" vClass="emergency" guiShape="police" color="1,0,0" accel="3.0" decel="5.0" sigma="0.5" length="5.0" minGap="2.0" maxSpeed="38.89"/>
    <vType id="firetruck" vClass="emergency" guiShape="firebrigade" color="1,0,0" accel="2.0" decel="4.0" sigma="0.5" length="10.0" minGap="3.0" maxSpeed="27.78"/>

    <!-- 8 Straight Routes Across the Grid -->
    <route id="route_top_east" edges="edge_A_west_in edge_AB_east edge_B_east_out"/>
    <route id="route_top_west" edges="edge_B_east_in edge_AB_west edge_A_west_out"/>
    <route id="route_bottom_east" edges="edge_D_west_in edge_CD_east edge_C_east_out"/>
    <route id="route_bottom_west" edges="edge_C_east_in edge_CD_west edge_D_west_out"/>
    <route id="route_left_south" edges="edge_A_north_in edge_AD_south edge_D_south_out"/>
    <route id="route_left_north" edges="edge_D_south_in edge_AD_north edge_A_north_out"/>
    <route id="route_right_south" edges="edge_B_north_in edge_BC_south edge_C_south_out"/>
    <route id="route_right_north" edges="edge_C_south_in edge_BC_north edge_B_north_out"/>

    <!-- Low Density Flows for Top Street -->
    <flow id="flow_car_top_e" begin="0" end="3600" period="exp(15)" route="route_top_east" type="passenger"/>
    <flow id="flow_moto_top_e" begin="0" end="3600" period="exp(30)" route="route_top_east" type="motorcycle"/>
    <flow id="flow_car_top_w" begin="0" end="3600" period="exp(15)" route="route_top_west" type="passenger"/>
    <flow id="flow_bus_top_w" begin="0" end="3600" period="180" route="route_top_west" type="bus"/>

    <!-- Low Density Flows for Bottom Street -->
    <flow id="flow_car_bot_e" begin="0" end="3600" period="exp(15)" route="route_bottom_east" type="passenger"/>
    <flow id="flow_car_bot_w" begin="0" end="3600" period="exp(15)" route="route_bottom_west" type="passenger"/>
    <flow id="flow_moto_bot_w" begin="0" end="3600" period="exp(35)" route="route_bottom_west" type="motorcycle"/>

    <!-- Low Density Flows for Left Street -->
    <flow id="flow_car_left_s" begin="0" end="3600" period="exp(15)" route="route_left_south" type="passenger"/>
    <flow id="flow_car_left_n" begin="0" end="3600" period="exp(15)" route="route_left_north" type="passenger"/>
    <flow id="flow_bus_left_n" begin="0" end="3600" period="180" route="route_left_north" type="bus"/>

    <!-- Low Density Flows for Right Street -->
    <flow id="flow_car_right_s" begin="0" end="3600" period="exp(15)" route="route_right_south" type="passenger"/>
    <flow id="flow_moto_right_s" begin="0" end="3600" period="exp(30)" route="route_right_south" type="motorcycle"/>
    <flow id="flow_car_right_n" begin="0" end="3600" period="exp(15)" route="route_right_north" type="passenger"/>

    <!-- Sparse emergency vehicle flows -->
    <flow id="flow_amb_A" begin="0" end="3600" period="240" route="route_top_east" type="ambulance"/>
    <flow id="flow_pol_B" begin="0" end="3600" period="260" route="route_right_south" type="police"/>
    <flow id="flow_fire_D" begin="0" end="3600" period="280" route="route_left_north" type="firetruck"/>
</routes>
